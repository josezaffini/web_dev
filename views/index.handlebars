<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>ChocoDelícia - Loja de Chocolates</title>

<style>

body{
font-family: Arial;
margin:0;
background:#f5e6d3;
}

header{
background:#4b2e2e;
color:white;
padding:20px;
text-align:center;
}

nav{
background:#6b3e26;
padding:10px;
text-align:center;
}

nav a{
color:white;
margin:15px;
text-decoration:none;
font-weight:bold;
}

.container{
padding:30px;
display:flex;
gap:20px;
justify-content:center;
flex-wrap:wrap;
}

.produto{
background:white;
padding:20px;
border-radius:10px;
width:200px;
text-align:center;
box-shadow:0px 0px 10px rgba(0,0,0,0.1);
}

.produto img{
width:100%;
border-radius:10px;
}

button{
background:#8b4513;
color:white;
border:none;
padding:10px;
margin-top:10px;
cursor:pointer;
border-radius:5px;
}

footer{
background:#4b2e2e;
color:white;
text-align:center;
padding:15px;
margin-top:40px;
}

</style>
</head>

<body>

<header>
<h1>🍫 ChocoDelícia</h1>
<p>Os melhores chocolates artesanais</p>
</header>

<nav>
<a href="index.handlebars">Início</a>
<a href="sobre">Sobre</a>
</nav>

<section class="container">

<div class="produto">
<img src="https://via.placeholder.com/200">
<h3>Chocolate ao Leite</h3>
<p>R$ 12,00</p>
<button>Comprar</button>
</div>

<div class="produto">
<img src="https://via.placeholder.com/200">
<h3>Chocolate Amargo</h3>
<p>R$ 15,00</p>
<button>Comprar</button>
</div>

<div class="produto">
<img src="https://via.placeholder.com/200">
<h3>Trufa Especial</h3>
<p>R$ 10,00</p>
<button>Comprar</button>
</div>

</section>

<footer>
<p>© 2026 ChocoDelícia</p>
</footer>

</body>
</html>